# ── Match-Trader Broker API v2 ────────────────────────────────────────────────
# Base REST URL. Demo/UAT sandbox shown; production is
# https://broker-api-v2-<clientName>.match-trader.com (ask Match-Trade IT-Support).
BROKER_API_URL=https://broker-api-v2-demo.match-trader.com

# Bearer token issued by Match-Trade IT-Support (itsupport@match-trade.com).
# Leave empty to run the site with built-in demo data (no real API calls).
BROKER_API_TOKEN=

# Trading-account group used for sign-ups and symbol lookups.
# Must exist for your broker — check GET /v1/group-names.
BROKER_GROUP=testUSD

# gRPC quote stream host (live prices). Leave as-is for the demo environment;
# set BROKER_GRPC_HOST= (empty) to disable gRPC and poll REST candles instead.
BROKER_GRPC_HOST=grpc-broker-api-v2-demo.match-trader.com:8083

# ── App behaviour ─────────────────────────────────────────────────────────────
# live  — real Broker API calls (requires BROKER_API_TOKEN)
# mock  — built-in demo markets + simulated prices, no network calls
# Default: live when a token is set, mock otherwise.
BROKER_MODE=

# Secret for signing session cookies. Any long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Deposit granted to newly created demo accounts, and the top-up amount cap.
DEMO_INITIAL_DEPOSIT=10000

# Set to "true" to hide the demo top-up button entirely.
DISABLE_DEPOSITS=
